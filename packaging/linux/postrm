#!/bin/sh
# Segra .deb post-removal: drop the apt repo entry on purge and refresh desktop caches.
set -e

if [ "$1" = "purge" ]; then
    rm -f /etc/apt/sources.list.d/segra.list
fi

update-desktop-database -q /usr/share/applications 2>/dev/null || true
gtk-update-icon-cache -qf /usr/share/icons/hicolor 2>/dev/null || true

exit 0
